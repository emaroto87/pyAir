$$                      Bulk Data Cards                                         $
$$------------------------------------------------------------------------------$
BEGIN BULK
$
$-------------------------------------------------------------------------------
$ Parameter
$-------------------------------------------------------------------------------
$ Check that density is in value*E-6 for mass in kg
PARAM,WTMASS,0.001
$ OP2 Output File
PARAM,POST,-1
$ Mechanisms will be detected as an fatal error
PARAM,BAILOUT,0
$ Causes generation of lumped mass matrices
PARAM,COUPMASS,-1
$ In Case of Postprocessing with S2K and DIANA database generation
$PARAM,NOCOMPS,-1
$ Print max loads and displacments
PARAM,PRTMAXIM,NO
$ Grid Point Weight Generator
PARAM,GRDPNT,0
$ Results in material axis
PARAM,OMID,YES
$
$$ Real eigenvalue parameter (only SOL103 & SOL105)
$EIGRL   2            -1.      50
$
$ Composite Output Parameter
$PARAM, CDITER, 50
$PARAM, CDPCH, YES
$PARAM, CDPRT, NO
$
