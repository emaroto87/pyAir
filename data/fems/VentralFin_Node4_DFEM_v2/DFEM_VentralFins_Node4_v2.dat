$$------------------------------------------------------------------------------$
$$                      Case Control Cards                                      $
$$------------------------------------------------------------------------------$
$
TITLE = DFEM_2D_REAR-FUS_VentralFins_Node4
$
$ RBAR and RBE will calculated in thermal analysis
$RIGID = LAGRAN
$
$ Data Selection
$ Print singularity table
AUTOSPC(PRINT) = NO
$
$ Output Selection
$ Don't print bulk data
$ECHO = NONE
$ Print sorted bulk data in alphanumeric order
$ECHO = SORT
$
$$$ SETS
$ ----------------------------------------------
$
INCLUDE '04_SETS/Sets_v2.bdf'
$
$$$ OUTPUT REQUEST
$ ----------------------------------------------
$ Output Requests
  DISPLACEMENT(PLOT) = ALL
  MPCFORCES(PRINT,PLOT) = ALL
  ELFORCES(PRINT,PLOT) = 5
  STRESS(PLOT) = ALL
